<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pokédex</title>

  <!-- Tailwind CSS Play CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon -->
  <link
    rel="icon"
    href="https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/25.png"
    type="image/png"
  />

  <!-- Tailwind Configuration -->
  <script>
    tailwind.config = {
      theme: {
        fontFamily: {
          sans: ['"Plus Jakarta Sans"', 'sans-serif']
        },
        extend: {
          colors: {
            'pokemon-red': '#EE1515',
            'pokemon-blue': '#3B4CCA',
            'pokemon-yellow': '#F9D537',
            'pokemon-green': '#78B82F',
            'pokemon-purple': '#A040DF',
            'type-normal': '#A8A878',
            'type-fighting': '#C03028',
            'type-flying': '#A890F0',
            'type-poison': '#A040A0',
            'type-ground': '#E0C068',
            'type-rock': '#B8A038',
            'type-bug': '#A8B820',
            'type-ghost': '#705898',
            'type-steel': '#B8B8D0',
            'type-fire': '#F08030',
            'type-water': '#6890F0',
            'type-grass': '#78C850',
            'type-electric': '#F8D030',
            'type-psychic': '#F85888',
            'type-ice': '#98D8D8',
            'type-dragon': '#7038F8',
            'type-dark': '#705848',
            'type-fairy': '#EE99AC',
            'type-unknown': '#68A090',
            'type-shadow': '#705898'
          },
          boxShadow: {
            'pokemon': '0 4px 15px rgba(0, 0, 0, 0.2)',
            'pokemon-lg': '0 8px 30px rgba(0, 0, 0, 0.25)'
          },
          animation: {
            'pulse-glow': 'pulse-glow 2s cubic-bezier(0.4, 0, 0.6, 1) infinite',
            'slide-up': 'slide-up 0.5s ease-out'
          },
          keyframes: {
            'pulse-glow': {
              '0%, 100%': { opacity: '1' },
              '50%': { opacity: '0.7' }
            },
            'slide-up': {
              'from': {
                opacity: '0',
                transform: 'translateY(20px)'
              },
              'to': {
                opacity: '1',
                transform: 'translateY(0)'
              }
            }
          }
        }
      }
    };
  </script>

  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* Global utility styles */
    .type-badge {
      @apply inline-block px-3 py-1 rounded-full text-xs font-semibold text-white uppercase tracking-wide;
    }

    .pokemon-card {
      @apply rounded-xl overflow-hidden shadow-pokemon hover:shadow-pokemon-lg transition-all duration-300 hover:scale-105 cursor-pointer bg-white;
    }

    .stat-bar {
      @apply h-2 rounded-full bg-gray-200 overflow-hidden;
    }

    .stat-fill {
      @apply h-full rounded-full transition-all duration-1000 ease-out;
    }

    .animate-blob {
      animation: blob 7s infinite;
    }

    .animation-delay-2000 {
      animation-delay: 2s;
    }

    .animation-delay-4000 {
      animation-delay: 4s;
    }

    @keyframes blob {
      0%,
      100% {
        transform: translate(0, 0) scale(1);
      }
      33% {
        transform: translate(30px, -50px) scale(1.1);
      }
      66% {
        transform: translate(-20px, 20px) scale(0.9);
      }
    }

    /* Scrollbar styling */
    ::-webkit-scrollbar {
      width: 8px;
    }

    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }

    ::-webkit-scrollbar-thumb {
      background: #888;
      border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #555;
    }
  </style>
</head>
<body class="bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50">
  <!-- Decorative background blobs -->
  <div
    class="fixed -top-40 -right-40 w-80 h-80 bg-pokemon-blue opacity-20 rounded-full animate-blob"
  ></div>
  <div
    class="fixed -bottom-40 -left-40 w-80 h-80 bg-pokemon-red opacity-20 rounded-full animate-blob animation-delay-2000"
  ></div>
  <div
    class="fixed top-1/2 left-1/2 w-80 h-80 bg-pokemon-yellow opacity-20 rounded-full animate-blob animation-delay-4000"
  ></div>

  <!-- Navigation Bar -->
  <nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a
          href="/"
          class="flex items-center gap-3 group"
        >
          <div class="w-10 h-10 bg-gradient-to-br from-pokemon-red to-pokemon-yellow rounded-full flex items-center justify-center shadow-md group-hover:scale-110 transition-transform">
            <span class="text-white font-bold text-lg">P</span>
          </div>
          <span class="font-bold text-xl text-gray-900 group-hover:text-pokemon-red transition-colors">
            Pokédex
          </span>
        </a>

        <!-- Search Form -->
        <form
          method="get"
          action="/search"
          class="flex-1 max-w-md mx-8"
        >
          <div class="relative">
            <input
              type="text"
              name="q"
              placeholder="Search Pokémon..."
              value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
              class="w-full px-4 py-2 pl-10 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-pokemon-blue focus:border-transparent"
            />
            <svg
              class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
              ></path>
            </svg>
          </div>
        </form>

        <!-- GitHub Link -->
        <a
          href="https://github.com/PokeAPI/pokeapi"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-600 hover:text-pokemon-blue transition-colors"
        >
          <svg
            class="w-6 h-6"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              d="M10 0C4.477 0 0 4.477 0 10c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.868-.013-1.703-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.544 2.914 1.186.092-.923.35-1.544.636-1.898-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0110 4.817a9.591 9.591 0 012.502.336c1.906-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C17.138 18.163 20 14.413 20 10c0-5.523-4.477-10-10-10z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
