<%- include('partials/header') %>

<article class="animate-fade-up">
	<div class="grid gap-8 lg:grid-cols-[minmax(0,320px)_minmax(0,1fr)]">
		<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
			<div class="flex items-center justify-between text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">
				<span>#<%= String(pokemon.id).padStart(3, '0') %></span>
				<span><%= (pokemon.types || []).join(' / ') %></span>
			</div>

			<div class="mt-6 flex justify-center">
				<img src="<%= pokemon.image || pokemon.sprite || '' %>" alt="<%= pokemon.displayName %>" class="h-64 w-64 object-contain" />
			</div>

			<h1 class="mt-6 text-3xl font-extrabold tracking-tight text-slate-900"><%= pokemon.displayName %></h1>
			<p class="mt-2 text-slate-600"><%= pokemon.genus %></p>
			<p class="mt-4 text-sm leading-7 text-slate-600"><%= pokemon.description %></p>
		</section>

		<section class="space-y-6">
			<div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
				<h2 class="text-lg font-bold text-slate-900">Base stats</h2>
				<div class="mt-5 space-y-4">
					<% pokemon.stats.forEach((stat) => { %>
						<div>
							<div class="mb-1 flex items-center justify-between text-sm font-medium text-slate-600">
								<span><%= stat.name %></span>
								<span><%= stat.value %></span>
							</div>
							<div class="h-2 overflow-hidden rounded-full bg-slate-100">
								<div class="stat-bar h-full rounded-full bg-gradient-to-r from-brand-500 to-brand-600" style="width: <%= Math.min(stat.value, 100) %>%"></div>
							</div>
						</div>
					<% }) %>
				</div>
			</div>

			<div class="grid gap-6 md:grid-cols-2">
				<div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
					<h2 class="text-lg font-bold text-slate-900">Abilities</h2>
					<ul class="mt-4 space-y-2 text-sm text-slate-600">
						<% pokemon.abilities.forEach((ability) => { %>
							<li><%= ability.name %><%= ability.isHidden ? ' (hidden)' : '' %></li>
						<% }) %>
					</ul>
				</div>

				<div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
					<h2 class="text-lg font-bold text-slate-900">Profile</h2>
					<dl class="mt-4 grid grid-cols-2 gap-4 text-sm">
						<div>
							<dt class="text-slate-500">Height</dt>
							<dd class="mt-1 font-semibold text-slate-900"><%= pokemon.height %> m</dd>
						</div>
						<div>
							<dt class="text-slate-500">Weight</dt>
							<dd class="mt-1 font-semibold text-slate-900"><%= pokemon.weight %> kg</dd>
						</div>
						<div>
							<dt class="text-slate-500">Capture rate</dt>
							<dd class="mt-1 font-semibold text-slate-900"><%= pokemon.captureRate %></dd>
						</div>
						<div>
							<dt class="text-slate-500">Base happiness</dt>
							<dd class="mt-1 font-semibold text-slate-900"><%= pokemon.baseHappiness %></dd>
						</div>
					</dl>
				</div>
			</div>
		</section>
	</div>
</article>

<%- include('partials/footer') %>
