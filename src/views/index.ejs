<%- include('partials/header') %>

<section class="animate-fade-up">
	<div class="mx-auto max-w-3xl text-center">
		<p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-600">Pokédex</p>
		<h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">Discover every Pokémon</h1>
		<p class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-slate-600">
			Search by name or ID, browse by type, and inspect the details behind each entry.
		</p>
	</div>

	<div class="mt-10 grid gap-6 lg:grid-cols-[260px_minmax(0,1fr)]">
		<aside class="rounded-3xl border border-slate-200 bg-white p-5 shadow-card">
			<h2 class="text-sm font-bold uppercase tracking-[0.2em] text-slate-500">Types</h2>
			<div class="mt-4 flex flex-wrap gap-2">
				<% (types || []).forEach((type) => { %>
					<a href="/type/<%= type.name %>" class="rounded-full bg-slate-100 px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:bg-brand-100 hover:text-brand-700"><%= type.displayName %></a>
				<% }) %>
			</div>
		</aside>

		<section class="rounded-3xl border border-slate-200 bg-white p-5 shadow-card">
			<div class="flex items-center justify-between gap-4 border-b border-slate-100 pb-4">
				<div>
					<h2 class="text-xl font-bold text-slate-900">Pokémon results</h2>
					<p class="mt-1 text-sm text-slate-500"><%= totalCount || 0 %> Pokémon found</p>
				</div>
			</div>

			<% if (pokemon && pokemon.length) { %>
				<div class="mt-5 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
					<% pokemon.forEach((entry) => { %>
						<a href="/pokemon/<%= entry.name %>" class="group rounded-2xl border border-slate-200 p-4 transition hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-lift">
							<div class="flex items-center justify-between gap-3">
								<span class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">#<%= String(entry.id).padStart(3, '0') %></span>
								<span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600"><%= entry.types && entry.types[0] ? entry.types[0] : 'unknown' %></span>
							</div>
							<div class="mt-4 flex items-center gap-4">
								<img src="<%= entry.sprite || entry.image || '' %>" alt="<%= entry.displayName %>" class="h-20 w-20 object-contain" />
								<div>
									<h3 class="text-lg font-bold text-slate-900"><%= entry.displayName %></h3>
									<p class="mt-1 text-sm text-slate-500">Total stats: <%= entry.totalStats %></p>
								</div>
							</div>
						</a>
					<% }) %>
				</div>
			<% } else { %>
				<div class="py-16 text-center text-slate-500">No Pokémon to show yet.</div>
			<% } %>

			<% if ((totalPages || 0) > 1) { %>
				<%
					const basePath = selectedType
						? `/type/${selectedType}?page=`
						: searchQuery
							? `/search?q=${encodeURIComponent(searchQuery)}&page=`
							: '/?page=';
				%>
				<div class="mt-6 flex flex-col items-center gap-3 border-t border-slate-100 pt-4 sm:flex-row sm:justify-between">
					<p class="text-sm text-slate-500">Page <%= currentPage || 1 %> of <%= totalPages %></p>
					<div class="flex items-center gap-2">
						<% if (hasPrevPage) { %>
							<a href="<%= basePath + ((currentPage || 1) - 1) %>" class="rounded-xl border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-brand-200 hover:text-brand-700">Previous</a>
						<% } else { %>
							<span class="rounded-xl border border-slate-100 px-3 py-2 text-sm font-semibold text-slate-300">Previous</span>
						<% } %>

						<% if (hasNextPage) { %>
							<a href="<%= basePath + ((currentPage || 1) + 1) %>" class="rounded-xl border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-brand-200 hover:text-brand-700">Next</a>
						<% } else { %>
							<span class="rounded-xl border border-slate-100 px-3 py-2 text-sm font-semibold text-slate-300">Next</span>
						<% } %>
					</div>
				</div>
			<% } %>
		</section>
	</div>
</section>

<%- include('partials/footer') %>
